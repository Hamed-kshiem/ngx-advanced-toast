{
  "name": "ngx-advanced-toast",
  "version": "21.0.1",
    "repository": {
    "type": "git",
    "url": "https://github.com/Hamed-kshiem/ngx-advanced-toast.git"
  },
  "homepage": "https://ngx-advanced-toast.vercel.app/",
  "author": {"name": "Hamed Kshiem"},
  "license": "MIT",
  "description": "Advanced toast notifications for Angular applications. Easy to use, fully themeable, and built with performance in mind. No external dependencies.",
  "keywords": [
    "angular",
    "toast",
    "notifications",
    "angular-toast",
    "snackbar",
    "ui",
    "components"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build": "ng build ngx-advanced-toast --configuration production",
    "build:demo": "ng build demo --configuration production",
    "build:all": "npm run build && npm run build:demo",
    "watch": "ng build ngx-advanced-toast --configuration development --watch",
    "serve": "ng serve demo --configuration development",
    "test": "ng test",
    "release": "npm run build && cd dist/ngx-advanced-toast && npm publish"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
